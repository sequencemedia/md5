{
  "compilerOptions": {
    "module": "NodeNext",
    "target": "ESNext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "isolatedModules": true
  },
  "include": [
    "*.mjs",
    "*.mts",
    "src/**/*.mjs",
    "src/**/*.mts"
  ],
  "exclude": [
    "test"
  ]
}
